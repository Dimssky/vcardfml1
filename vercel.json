{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.1"
    },
    "api/download_vcf.php": {
      "runtime": "vercel-php@0.6.1"
    }
  },
  "rewrites": [
    {
      "source": "/image/(.*)",
      "destination": "/image/$1"
    },
    {
      "source": "/download_vcf.php",
      "destination": "/api/download_vcf.php"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
