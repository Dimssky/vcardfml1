{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
{
  "rewrites": [
    {
      "source": "/image/(.*)",
      "destination": "/image/$1"
    },
    {
      "source": "/download_vcf.php",
      "destination": "/api/download_vcf.php"
    },
  
  ]
}
